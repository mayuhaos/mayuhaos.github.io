---
import QRCode from "qrcode";
import { Icon } from "astro-icon/components";
import { encryptContent } from "@utils/crypto-utils";
import { siteConfig } from "@/config/siteConfig";

interface Props {
	password: string;
	slug: string;
	title: string;
	hint?: string;
}

const { password, slug, title, hint = "" } = Astro.props;

const rawHtml = await Astro.slots.render("default");
const encryptedData = encryptContent(rawHtml, password, slug);

const unlockConfig = siteConfig.wechatUnlock;
const isChinese =
	siteConfig.lang === "zh_CN" || siteConfig.lang === "zh_TW";

let qrImageSrc = unlockConfig.qrImage?.trim() ?? "";
if (!qrImageSrc && unlockConfig.qrLink?.trim()) {
	qrImageSrc = await QRCode.toDataURL(unlockConfig.qrLink, {
		margin: 1,
		width: 320,
	});
}

const labels = isChinese
	? {
			protected: "\u516c\u4f17\u53f7\u53e3\u4ee4\u89e3\u9501",
			desc: "\u8fd9\u7bc7\u6587\u7ae0\u5df2\u52a0\u5bc6\uff0c\u8bf7\u5148\u5173\u6ce8\u516c\u4f17\u53f7\uff0c\u56de\u590d\u5173\u952e\u8bcd\u540e\u67e5\u770b\u5f53\u65e5\u53e3\u4ee4\u3002",
			step1: "\u626b\u7801\u5173\u6ce8\u516c\u4f17\u53f7",
			step2: `\u56de\u590d\u5173\u952e\u8bcd\u201c${unlockConfig.keyword}\u201d`,
			step3: "\u6253\u5f00\u53e3\u4ee4\u9875\u67e5\u770b\u4eca\u65e5\u53e3\u4ee4",
			step4: "\u56de\u5230\u672c\u9875\u8f93\u5165\u53e3\u4ee4\u89e3\u9501",
			keyword: "\u5173\u952e\u8bcd",
			keywordAction: "\u590d\u5236\u5173\u952e\u8bcd",
			keywordCopied: "\u5df2\u590d\u5236\u5173\u952e\u8bcd",
			keywordCopyFailed: "\u590d\u5236\u5931\u8d25\uff0c\u8bf7\u624b\u52a8\u590d\u5236",
			viewCodePage: "\u6253\u5f00\u53e3\u4ee4\u9875",
			accountName: "\u516c\u4f17\u53f7",
			placeholder: "\u8bf7\u8f93\u5165\u5f53\u524d\u52a8\u6001\u53e3\u4ee4",
			submit: "\u89e3\u9501\u6587\u7ae0",
			submitting: "\u6b63\u5728\u9a8c\u8bc1...",
			errorDefault: "\u53e3\u4ee4\u9519\u8bef\u6216\u5df2\u8fc7\u671f\uff0c\u8bf7\u91cd\u65b0\u83b7\u53d6\u3002",
			errorConfig: "\u53e3\u4ee4\u6570\u636e\u6682\u672a\u751f\u6210\uff0c\u8bf7\u7a0d\u540e\u518d\u8bd5\u3002",
			errorKeyMissing: "\u672a\u627e\u5230\u8fd9\u7bc7\u6587\u7ae0\u7684\u89e3\u9501\u5bc6\u94a5\uff0c\u8bf7\u68c0\u67e5\u5b9a\u65f6\u751f\u6210\u811a\u672c\u3002",
			errorNetwork: "\u52a0\u8f7d\u53e3\u4ee4\u6570\u636e\u5931\u8d25\uff0c\u8bf7\u7a0d\u540e\u518d\u8bd5\u3002",
			errorUnknown: "\u89e3\u9501\u5931\u8d25\uff0c\u8bf7\u7a0d\u540e\u518d\u8bd5\u3002",
			errorExpired: "\u5f53\u524d\u53e3\u4ee4\u7a97\u53e3\u5df2\u5207\u6362\uff0c\u8bf7\u56de\u516c\u4f17\u53f7\u91cd\u65b0\u67e5\u770b\u53e3\u4ee4\u3002",
			qrUnavailable: "\u6682\u672a\u914d\u7f6e\u516c\u4f17\u53f7\u4e8c\u7ef4\u7801\u3002",
			window: "\u53e3\u4ee4\u6bcf 12 \u5c0f\u65f6\u81ea\u52a8\u66f4\u65b0\u4e00\u6b21\u3002",
			hintLabel: "\u63d0\u793a",
			qrAlt: "\u516c\u4f17\u53f7\u4e8c\u7ef4\u7801",
		}
	: {
			protected: "Unlock With WeChat",
			desc: "This post is encrypted. Follow the WeChat account, reply with the keyword, then open the code page to get the current unlock code.",
			step1: "Scan to follow the WeChat account",
			step2: `Reply with the keyword "${unlockConfig.keyword}"`,
			step3: "Open the code page to view the current code",
			step4: "Come back and enter the code to unlock",
			keyword: "Keyword",
			keywordAction: "Copy keyword",
			keywordCopied: "Keyword copied",
			keywordCopyFailed: "Copy failed. Please copy it manually.",
			viewCodePage: "Open code page",
			accountName: "WeChat account",
			placeholder: "Enter the current unlock code",
			submit: "Unlock post",
			submitting: "Verifying...",
			errorDefault: "The code is invalid or expired. Please request a new one.",
			errorConfig: "Unlock data is not ready yet.",
			errorKeyMissing: "The article key was not found in the generated unlock data.",
			errorNetwork: "Unlock data could not be loaded. Please try again later.",
			errorUnknown: "Unlock failed. Please try again later.",
			errorExpired: "The current code window has already changed. Please request the latest code again.",
			qrUnavailable: "No QR code is configured yet.",
			window: "The code refreshes every 12 hours.",
			hintLabel: "Hint",
			qrAlt: "WeChat QR code",
		};

const runtimeConfig = {
	dataUrl: unlockConfig.enabled ? unlockConfig.apiBase : "",
	keyword: unlockConfig.keyword,
	codePagePath: unlockConfig.codePagePath,
	labels: {
		defaultError: labels.errorDefault,
		configError: labels.errorConfig,
		keyMissingError: labels.errorKeyMissing,
		networkError: labels.errorNetwork,
		unknownError: labels.errorUnknown,
		expiredError: labels.errorExpired,
		submit: labels.submit,
		submitting: labels.submitting,
		copySuccess: labels.keywordCopied,
		copyFailed: labels.keywordCopyFailed,
	},
};
---

<div
	id="encrypted-container"
	data-encrypted={encryptedData}
	data-slug={slug}
	data-runtime={JSON.stringify(runtimeConfig)}
>
	<div id="password-ui" class="flex justify-center py-16 px-4">
		<div class="card-base flex flex-col gap-6 max-w-5xl w-full p-6 md:p-8">
			<div class="flex flex-col items-center gap-3 text-center">
				<div class="h-20 w-20 rounded-3xl bg-(--primary)/12 text-(--primary) flex items-center justify-center">
					<Icon name="material-symbols:shield-lock" class="text-5xl" />
				</div>
				<h2 class="text-2xl font-bold text-black/85 dark:text-white/85 m-0">
					{labels.protected}
				</h2>
				<p class="text-sm md:text-base text-black/45 dark:text-white/45 text-center m-0 max-w-2xl">
					{labels.desc}
				</p>
				<p class="text-sm text-black/55 dark:text-white/55 m-0">
					{title}
				</p>
			</div>

			<div class="grid gap-4 md:grid-cols-[minmax(0,18rem)_minmax(0,1fr)]">
				<div class="rounded-2xl bg-black/4 dark:bg-white/6 border border-black/6 dark:border-white/8 p-5 flex flex-col items-center gap-4">
					<div class="text-sm font-medium text-black/70 dark:text-white/75">
						{labels.accountName}: {unlockConfig.name}
					</div>
					{
						qrImageSrc ? (
							<img
								src={qrImageSrc}
								alt={labels.qrAlt}
								class="w-full max-w-56 aspect-square rounded-2xl bg-white object-contain p-2 shadow-sm"
								loading="lazy"
								decoding="async"
							/>
						) : (
							<div class="w-full max-w-56 aspect-square rounded-2xl border border-dashed border-black/10 dark:border-white/12 bg-white/70 dark:bg-black/10 flex items-center justify-center text-center text-sm text-black/45 dark:text-white/45 px-6">
								{labels.qrUnavailable}
							</div>
						)
					}
					<div class="inline-flex items-center gap-2 rounded-full bg-black/5 dark:bg-white/8 px-3 py-1 text-xs text-black/60 dark:text-white/60">
						<Icon name="material-symbols:timer-outline-rounded" class="text-base" />
						<span>{labels.window}</span>
					</div>
				</div>

				<div class="rounded-2xl bg-black/3 dark:bg-white/5 border border-black/6 dark:border-white/8 p-5 md:p-6">
					<ol class="m-0 pl-5 space-y-3 text-sm md:text-base text-black/75 dark:text-white/78">
						<li>{labels.step1}</li>
						<li>
							<span>{labels.step2}</span>
							<button
								id="copy-keyword"
								type="button"
								class="ml-3 inline-flex items-center gap-1 rounded-full bg-black/5 dark:bg-white/10 px-3 py-1 text-xs font-medium text-black/65 dark:text-white/75 hover:bg-black/8 dark:hover:bg-white/14 transition"
							>
								<Icon name="material-symbols:content-copy-outline-rounded" class="text-sm" />
								<span>{labels.keywordAction}</span>
							</button>
						</li>
						<li>
							<div class="flex flex-wrap items-center gap-3">
								<span>{labels.step3}</span>
								<a
									href={unlockConfig.codePagePath}
									target="_blank"
									rel="noopener noreferrer"
									class="inline-flex items-center gap-1 rounded-full bg-(--primary)/10 text-(--primary) px-3 py-1 text-xs font-medium hover:bg-(--primary)/15 transition"
								>
									<Icon name="material-symbols:open-in-new-rounded" class="text-sm" />
									<span>{labels.viewCodePage}</span>
								</a>
							</div>
						</li>
						<li>{labels.step4}</li>
					</ol>

					<div class="mt-5 rounded-2xl bg-(--primary)/8 border border-(--primary)/20 p-4">
						<div class="text-xs uppercase tracking-[0.2em] text-(--primary)/80">
							{labels.keyword}
						</div>
						<div class="mt-2 flex items-center gap-3">
							<div class="text-xl md:text-2xl font-semibold text-(--primary)">
								{unlockConfig.keyword}
							</div>
							<div
								id="copy-keyword-feedback"
								class="text-xs text-black/45 dark:text-white/45 min-h-[1rem]"
								aria-live="polite"
							></div>
						</div>
					</div>

					{hint && (
						<p class="mt-4 text-xs text-black/40 dark:text-white/40 m-0">
							{labels.hintLabel}: {hint}
						</p>
					)}

					<form id="password-form" class="mt-5 space-y-3">
						<input
							id="password-input"
							name="password"
							type="text"
							placeholder={labels.placeholder}
							autocomplete="one-time-code"
							spellcheck="false"
							class="w-full px-4 py-3 rounded-xl text-sm bg-black/5 dark:bg-white/10
								border border-black/8 dark:border-white/8
								text-black/80 dark:text-white/80 placeholder-black/30 dark:placeholder-white/30
								outline-none focus:border-(--primary) transition"
						/>
						<button
							id="password-submit"
							type="submit"
							class="w-full py-3 rounded-xl text-sm font-medium bg-(--primary) text-white dark:text-black/70
								hover:opacity-85 active:scale-[0.98] transition-all disabled:opacity-60 disabled:cursor-not-allowed"
						>
							{labels.submit}
						</button>
					</form>

					<p
						id="password-error"
						class="text-xs text-red-500 dark:text-red-400 m-0 mt-3 hidden"
						aria-live="polite"
					>
						{labels.errorDefault}
					</p>
				</div>
			</div>
		</div>
	</div>

	<div id="decrypted-content" class="hidden"></div>
</div>

<script is:inline>
(function() {
  var ITERATIONS = 100000;
  var SALT_LEN = 16;
  var IV_LEN = 12;
  var TAG_LEN = 16;

  var container = document.getElementById('encrypted-container');
  if (!container) return;

  var encryptedData = container.getAttribute('data-encrypted');
  var slug = container.getAttribute('data-slug');
  var runtime = JSON.parse(container.getAttribute('data-runtime') || '{}');
  var cacheKey = 'pw:key:' + slug;

  var ui = document.getElementById('password-ui');
  var form = document.getElementById('password-form');
  var input = document.getElementById('password-input');
  var submitButton = document.getElementById('password-submit');
  var errorEl = document.getElementById('password-error');
  var contentEl = document.getElementById('decrypted-content');
  var copyKeywordButton = document.getElementById('copy-keyword');
  var copyFeedbackEl = document.getElementById('copy-keyword-feedback');

  function showContent(html) {
    contentEl.innerHTML = html;
    contentEl.classList.remove('hidden');
    ui.classList.add('hidden');
    if (typeof window.mermaidInitialized !== 'undefined') {
      window.mermaidInitialized = false;
    }
    var scripts = contentEl.querySelectorAll('script');
    for (var i = 0; i < scripts.length; i++) {
      var old = scripts[i];
      var replacement = document.createElement('script');
      for (var j = 0; j < old.attributes.length; j++) {
        replacement.setAttribute(old.attributes[j].name, old.attributes[j].value);
      }
      replacement.textContent = old.textContent;
      old.parentNode.replaceChild(replacement, old);
    }
    setTimeout(function() {
      document.dispatchEvent(new CustomEvent('password:decrypted'));
    }, 100);
  }

  function setError(message) {
    errorEl.textContent = message || runtime.labels.defaultError;
    errorEl.classList.remove('hidden');
  }

  function clearError() {
    errorEl.classList.add('hidden');
    errorEl.textContent = runtime.labels.defaultError;
  }

  function setSubmitting(isSubmitting) {
    submitButton.disabled = isSubmitting;
    submitButton.textContent = isSubmitting
      ? runtime.labels.submitting
      : runtime.labels.submit;
  }

  function base64ToBytes(b64) {
    var bin = atob(b64);
    var bytes = new Uint8Array(bin.length);
    for (var i = 0; i < bin.length; i++) {
      bytes[i] = bin.charCodeAt(i);
    }
    return bytes;
  }

  async function decryptPayload(keyValue, payloadBase64) {
    var raw = base64ToBytes(payloadBase64);
    var salt = raw.slice(0, SALT_LEN);
    var iv = raw.slice(SALT_LEN, SALT_LEN + IV_LEN);
    var authTag = raw.slice(SALT_LEN + IV_LEN, SALT_LEN + IV_LEN + TAG_LEN);
    var ciphertext = raw.slice(SALT_LEN + IV_LEN + TAG_LEN);

    var combined = new Uint8Array(ciphertext.length + TAG_LEN);
    combined.set(ciphertext);
    combined.set(authTag, ciphertext.length);

    var enc = new TextEncoder();
    var keyMaterial = await crypto.subtle.importKey(
      'raw',
      enc.encode(keyValue),
      'PBKDF2',
      false,
      ['deriveBits', 'deriveKey']
    );
    var key = await crypto.subtle.deriveKey(
      { name: 'PBKDF2', salt: salt, iterations: ITERATIONS, hash: 'SHA-256' },
      keyMaterial,
      { name: 'AES-GCM', length: 256 },
      false,
      ['decrypt']
    );
    var decrypted = await crypto.subtle.decrypt({ name: 'AES-GCM', iv: iv }, key, combined);
    return new TextDecoder().decode(decrypted);
  }

  function normalizeDataUrl(url) {
    return (url || '').trim();
  }

  async function loadUnlockData() {
    var dataUrl = normalizeDataUrl(runtime.dataUrl);
    if (!dataUrl) {
      throw new Error(runtime.labels.configError);
    }

    var separator = dataUrl.indexOf('?') === -1 ? '?' : '&';
    var requestUrl = dataUrl + separator + 'ts=' + Date.now();

    var response;
    try {
      response = await fetch(requestUrl, {
        method: 'GET',
        cache: 'no-store',
        headers: { 'Accept': 'application/json' }
      });
    } catch (error) {
      throw new Error(runtime.labels.networkError);
    }

    if (!response.ok) {
      throw new Error(runtime.labels.networkError);
    }

    var payload;
    try {
      payload = await response.json();
    } catch (error) {
      throw new Error(runtime.labels.unknownError);
    }

    if (!payload || payload.ok === false) {
      throw new Error(runtime.labels.configError);
    }

    return payload;
  }

  function findActiveWindow(payload) {
    var windows = Array.isArray(payload.windows) ? payload.windows : [];
    var now = Date.now();

    for (var i = 0; i < windows.length; i++) {
      var item = windows[i];
      var startsAt = Date.parse(item.startsAt || '');
      var expiresAt = Date.parse(item.expiresAt || '');
      if (!Number.isNaN(startsAt) && !Number.isNaN(expiresAt) && now >= startsAt && now < expiresAt) {
        return item;
      }
    }

    return null;
  }

  function buildSlugCandidates(value) {
    var normalized = (value || '').replace(/^\/+|\/+$/g, '');
    var noExt = normalized.replace(/\.(md|mdx)$/i, '');
    var candidates = [normalized, noExt, noExt + '.md', noExt + '.mdx'];
    var unique = [];

    for (var i = 0; i < candidates.length; i++) {
      if (candidates[i] && unique.indexOf(candidates[i]) === -1) {
        unique.push(candidates[i]);
      }
    }

    return unique;
  }

  async function fetchArticleKey(code) {
    var payload = await loadUnlockData();
    var activeWindow = findActiveWindow(payload);

    if (!activeWindow) {
      throw new Error(runtime.labels.expiredError);
    }

    var articleKeys = activeWindow.articleKeys || {};
    var candidates = buildSlugCandidates(slug);
    var wrappedKey = '';
    for (var i = 0; i < candidates.length; i++) {
      if (articleKeys[candidates[i]]) {
        wrappedKey = articleKeys[candidates[i]];
        break;
      }
    }

    if (!wrappedKey) {
      throw new Error(runtime.labels.keyMissingError);
    }

    try {
      return await decryptPayload(code, wrappedKey);
    } catch (error) {
      throw new Error(runtime.labels.defaultError);
    }
  }

  async function copyKeyword() {
    if (!runtime.keyword) return;
    try {
      await navigator.clipboard.writeText(runtime.keyword);
      copyFeedbackEl.textContent = runtime.labels.copySuccess;
    } catch (error) {
      copyFeedbackEl.textContent = runtime.labels.copyFailed;
    }
    setTimeout(function() {
      copyFeedbackEl.textContent = '';
    }, 2400);
  }

  if (copyKeywordButton) {
    copyKeywordButton.addEventListener('click', copyKeyword);
  }

  form.addEventListener('submit', function(event) {
    event.preventDefault();
    var code = input.value.trim();
    if (!code) return;

    clearError();
    setSubmitting(true);

    fetchArticleKey(code)
      .then(function(articleKey) {
        sessionStorage.setItem(cacheKey, articleKey);
        return decryptPayload(articleKey, encryptedData);
      })
      .then(function(html) {
        showContent(html);
      })
      .catch(function(error) {
        setError(error && error.message ? error.message : runtime.labels.defaultError);
      })
      .finally(function() {
        setSubmitting(false);
      });
  });

  var cachedKey = sessionStorage.getItem(cacheKey);
  if (cachedKey) {
    decryptPayload(cachedKey, encryptedData)
      .then(function(html) {
        showContent(html);
      })
      .catch(function() {
        sessionStorage.removeItem(cacheKey);
      });
  }
})();
</script>
