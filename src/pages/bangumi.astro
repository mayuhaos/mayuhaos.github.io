---
import { Icon } from "astro-icon/components";
import BangumiSection from "@/components/pages/bangumi/BangumiSection.astro";
import TabNav from "@/components/pages/bangumi/TabNav.astro";
import { siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import type { UserSubjectCollection } from "@/types/bangumi";
import { formatDateI18nWithTime } from "@/utils/date-utils";

if (!siteConfig.pages.bangumi) {
	return Astro.redirect("/404/");
}

const buildTime = formatDateI18nWithTime(new Date());

function makeItem(id: number, name: string, type: number, collectionType: number, image: string, date?: string, score?: number): UserSubjectCollection {
	return {
		subject_id: id,
		subject_type: type as any,
		rate: 0,
		type: collectionType as any,
		tags: [],
		ep_status: 0,
		vol_status: 0,
		updated_at: new Date().toISOString(),
		private: false,
		subject: {
			id,
			type: type as any,
			name,
			name_cn: name,
			short_summary: "",
			date: date || null,
			images: { large: image, common: image, medium: image, small: image, grid: image },
			volumes: 0,
			eps: 0,
			collection_total: 0,
			score: score || 0,
			rank: 0,
			tags: [],
		},
	};
}

// 电影数据 (subjectType=2, collectionType: 1=想看, 2=看过, 3=在看)
const movieData: UserSubjectCollection[] = [
	makeItem(1, "隐入尘烟", 2, 2, "https://image.tmdb.org/t/p/w500/4wDdeLiGySFOJZTfpylq9hMTbpe.jpg", "2022-07-08", 8.5),
	makeItem(2, "飞屋环游记", 2, 2, "https://image.tmdb.org/t/p/w500/79R2HaSUTYBmxIrjDNouEtxjMQc.jpg", "2009-05-29", 9.1),
	makeItem(3, "寻梦环游记", 2, 2, "https://image.tmdb.org/t/p/w500/zrhUypo2z3aRX9htuzGpoVWE4jo.jpg", "2017-11-22", 9.2),
	makeItem(4, "驯龙高手", 2, 2, "https://image.tmdb.org/t/p/w500/2rNDBSL0xJO17oy8CZfOW8QjGKV.jpg", "2010-03-26", 8.7),
	makeItem(5, "三傻大闹宝莱坞", 2, 2, "https://image.tmdb.org/t/p/w500/3Kdkci7FE36fWcsuoeGFYApBBE1.jpg", "2009-12-25", 9.2),
	makeItem(6, "神秘巨星", 2, 1, "https://image.tmdb.org/t/p/w500/capwDy2o8U2kRMKSKZzsgzAS5cX.jpg", "2017-10-19", 7.8),
	makeItem(7, "暮光之城", 2, 3, "https://image.tmdb.org/t/p/w500/ytxwoZLN9F2JAcnsSE3ABgMWEWs.jpg", "2008-11-21", 6.3),
];

// 书籍数据 (subjectType=1)
const bookData: UserSubjectCollection[] = [
	makeItem(101, "蛤蟆先生去看心理医生", 1, 2, "https://covers.openlibrary.org/b/isbn/9787201161693-M.jpg", "2020-08-01", 8.4),
	makeItem(102, "长安的荔枝", 1, 1, "https://covers.openlibrary.org/b/isbn/9787572608889-M.jpg", "2022-10-01", 8.5),
	makeItem(103, "改命记实录", 1, 3, "https://img1.doubanio.com/view/subject/m/public/s34094erta.jpg", "2023-01-01", 0),
	makeItem(104, "骆驼祥子", 1, 2, "https://covers.openlibrary.org/b/isbn/9787020070589-M.jpg", "1939-01-01", 8.5),
	makeItem(105, "飘", 1, 1, "https://covers.openlibrary.org/b/isbn/9787544253178-M.jpg", "1936-06-30", 9.3),
	makeItem(106, "哑舍", 1, 1, "https://covers.openlibrary.org/b/isbn/9787549605552-M.jpg", "2011-09-01", 7.6),
];

// 音乐数据 (subjectType=3)
const musicData: UserSubjectCollection[] = [
	makeItem(201, "无名的人", 3, 2, "https://p2.music.126.net/6y-UleORITEDbvrOLV0Q8A==/5639395138885805.jpg", "2019-07-26", 0),
	makeItem(202, "问-梁静茹", 3, 3, "https://p2.music.126.net/wSMfGvFzOAYRU_yVIfquAA==/2946691248081599.jpg", "2004-09-01", 0),
];

// 游戏数据 (subjectType=4)
const gameData: UserSubjectCollection[] = [
	makeItem(301, "双人成行", 4, 2, "https://cdn.akamai.steamstatic.com/steam/apps/1426210/header.jpg", "2021-03-26", 9.1),
	makeItem(302, "麻布仔大冒险", 4, 2, "https://image.api.playstation.com/vulcan/ap/rnd/202212/0117/fFMrOczJMRIdeZKP4bSqH0sY.png", "2022-11-09", 8.5),
	makeItem(303, "8番出口", 4, 2, "https://cdn.akamai.steamstatic.com/steam/apps/2653790/header.jpg", "2023-11-29", 8.0),
	makeItem(304, "Q版泡泡堂", 4, 1, "https://cdn.akamai.steamstatic.com/steam/apps/252610/header.jpg", "2004-01-01", 0),
];

const bangumiData: Record<string, UserSubjectCollection[]> = {
	anime: movieData,
	book: bookData,
	music: musicData,
	game: gameData,
};

const tabs = [
	{ id: "anime", name: i18n(I18nKey.bangumiCategoryAnime), count: movieData.length },
	{ id: "book", name: i18n(I18nKey.bangumiCategoryBook), count: bookData.length },
	{ id: "music", name: i18n(I18nKey.bangumiCategoryMusic), count: musicData.length },
	{ id: "game", name: i18n(I18nKey.bangumiCategoryGame), count: gameData.length },
];

const activeTab = tabs[0]?.id || "anime";
---

<MainGridLayout title={i18n(I18nKey.bangumi)} description={i18n(I18nKey.bangumiSubtitle)}>
  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-9 py-6 relative w-full">
        <!-- 页面标题 -->
        <div class="relative w-full mb-8">
            <div class="mb-6">
                <div class="flex items-center gap-3 mb-3">
                    <div class="h-8 w-8 rounded-lg bg-(--primary) flex items-center justify-center text-white dark:text-black/70">
                        <Icon name="material-symbols:movie" class="text-[1.5rem]"></Icon>
                    </div>
                    <div class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
                        {i18n(I18nKey.bangumi)}
                    </div>
                </div>
                <p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed">
                    {i18n(I18nKey.bangumiSubtitle)}
                </p>
                <p class="text-xs text-neutral-500 dark:text-neutral-500 mt-2">
                    {i18n(I18nKey.bangumiLastUpdated)} {buildTime}
                </p>
            </div>

      <!-- Tab 导航和内容 -->
      {tabs.length > 0 ? (
        <>
          <TabNav tabs={tabs} activeTab={activeTab} />

          <!-- 内容区域 -->
          {tabs.map((tab) => (
                      <BangumiSection
            sectionId={tab.id}
            items={bangumiData[tab.id] || []}
            isActive={tab.id === activeTab}
            itemsPerPage={12}
          />
          ))}
        </>
      ) : (
        <div class="text-center py-16">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-(--btn-regular-bg) rounded-full mb-6 border border-(--line-divider)">
            <Icon name="material-symbols:settings" class="text-[2rem] text-(--btn-content)" />
          </div>
          <h2 class="text-xl font-semibold text-black/80 dark:text-white/80 mb-3">
            {i18n(I18nKey.bangumiEmpty)}
          </h2>
          <p class="text-black/60 dark:text-white/60 mb-4 max-w-md mx-auto">
            {i18n(I18nKey.bangumiEmptyReason)}
          </p>
        </div>
      )}
		</div>
    </div>
  </div>
</MainGridLayout>

<style>
  /* 自定义样式 */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>