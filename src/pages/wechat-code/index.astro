---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { siteConfig } from "@/config/siteConfig";

const unlockConfig = siteConfig.wechatUnlock;
const isChinese =
	siteConfig.lang === "zh_CN" || siteConfig.lang === "zh_TW";

const labels = isChinese
	? {
			title: "\u516c\u4f17\u53f7\u5f53\u524d\u53e3\u4ee4",
			description: "\u8fd9\u4e2a\u9875\u9762\u4f1a\u663e\u793a\u4eca\u65e5\u6709\u6548\u53e3\u4ee4\uff0c\u7528\u4e8e\u56de\u5230\u52a0\u5bc6\u6587\u7ae0\u9875\u89e3\u9501\u3002",
			keyword: "\u516c\u4f17\u53f7\u5173\u952e\u8bcd",
			code: "\u5f53\u524d\u53e3\u4ee4",
			expiresAt: "\u5931\u6548\u65f6\u95f4",
			loading: "\u6b63\u5728\u52a0\u8f7d\u6700\u65b0\u53e3\u4ee4...",
			error: "\u53e3\u4ee4\u6682\u672a\u751f\u6210\uff0c\u8bf7\u7a0d\u540e\u5237\u65b0\u3002",
			copy: "\u590d\u5236\u53e3\u4ee4",
			copied: "\u53e3\u4ee4\u5df2\u590d\u5236",
			copyFailed: "\u590d\u5236\u5931\u8d25\uff0c\u8bf7\u624b\u52a8\u590d\u5236",
			stepsTitle: "\u4f7f\u7528\u65b9\u6cd5",
			step1: "\u5173\u6ce8\u516c\u4f17\u53f7\u540e\u56de\u590d\u5173\u952e\u8bcd\u3002",
			step2: "\u5728\u8fd9\u91cc\u67e5\u770b\u5f53\u524d\u53e3\u4ee4\u3002",
			step3: "\u56de\u5230\u52a0\u5bc6\u6587\u7ae0\u9875\u8f93\u5165\u53e3\u4ee4\u89e3\u9501\u3002",
		}
	: {
			title: "Current WeChat Code",
			description: "This page shows the current unlock code for encrypted posts.",
			keyword: "Keyword",
			code: "Current code",
			expiresAt: "Expires at",
			loading: "Loading the latest code...",
			error: "The code is not ready yet. Please refresh later.",
			copy: "Copy code",
			copied: "Code copied",
			copyFailed: "Copy failed. Please copy it manually.",
			stepsTitle: "How to use",
			step1: "Follow the WeChat account and reply with the keyword.",
			step2: "View the current code on this page.",
			step3: "Return to the encrypted post and enter the code.",
		};

const pageRuntime = {
	dataUrl: unlockConfig.apiBase,
	labels,
};
---

<MainGridLayout title={labels.title} description={labels.description}>
	<div class="card-base p-6 md:p-8 w-full">
		<div class="max-w-3xl mx-auto flex flex-col gap-6">
			<div class="text-center">
				<h1 class="text-3xl font-bold text-black/85 dark:text-white/85 mb-3">
					{labels.title}
				</h1>
				<p class="text-sm md:text-base text-black/50 dark:text-white/55 m-0">
					{labels.description}
				</p>
			</div>

			<div class="grid gap-4 md:grid-cols-[minmax(0,1fr)_18rem]">
				<div class="rounded-2xl border border-black/6 dark:border-white/8 bg-black/3 dark:bg-white/5 p-5">
					<div class="text-xs uppercase tracking-[0.2em] text-(--primary)/80">
						{labels.code}
					</div>
					<div id="code-value" class="mt-3 text-4xl font-semibold tracking-[0.18em] text-(--primary)">
						----
					</div>
					<div class="mt-4 text-sm text-black/50 dark:text-white/55">
						{labels.expiresAt}: <span id="code-expire">--</span>
					</div>
					<div id="code-status" class="mt-3 text-sm text-black/45 dark:text-white/45">
						{labels.loading}
					</div>
					<button
						id="copy-code-button"
						type="button"
						class="mt-5 inline-flex items-center gap-2 rounded-full bg-(--primary) px-4 py-2 text-sm font-medium text-white dark:text-black/70 hover:opacity-90 transition"
					>
						{labels.copy}
					</button>
				</div>

				<div class="rounded-2xl border border-black/6 dark:border-white/8 bg-black/3 dark:bg-white/5 p-5">
					<div class="text-xs uppercase tracking-[0.2em] text-(--primary)/80">
						{labels.keyword}
					</div>
					<div class="mt-3 text-2xl font-semibold text-(--primary)">
						{unlockConfig.keyword}
					</div>
					<div class="mt-6 text-xs uppercase tracking-[0.2em] text-(--primary)/80">
						{labels.stepsTitle}
					</div>
					<ol class="mt-3 pl-5 space-y-3 text-sm text-black/65 dark:text-white/70">
						<li>{labels.step1}</li>
						<li>{labels.step2}</li>
						<li>{labels.step3}</li>
					</ol>
				</div>
			</div>
		</div>
	</div>

	<script is:inline define:vars={{ pageRuntime }}>
		(function () {
			var runtime = pageRuntime;
			var codeEl = document.getElementById("code-value");
			var expireEl = document.getElementById("code-expire");
			var statusEl = document.getElementById("code-status");
			var copyButton = document.getElementById("copy-code-button");
			var currentCode = "";

			function formatTime(value) {
				var date = new Date(value);
				if (Number.isNaN(date.getTime())) return "--";
				return date.toLocaleString("zh-CN", {
					hour12: false,
					year: "numeric",
					month: "2-digit",
					day: "2-digit",
					hour: "2-digit",
					minute: "2-digit",
					second: "2-digit",
				});
			}

			function findActiveWindow(payload) {
				var windows = Array.isArray(payload.windows) ? payload.windows : [];
				var now = Date.now();
				for (var i = 0; i < windows.length; i++) {
					var item = windows[i];
					var startsAt = Date.parse(item.startsAt || "");
					var expiresAt = Date.parse(item.expiresAt || "");
					if (!Number.isNaN(startsAt) && !Number.isNaN(expiresAt) && now >= startsAt && now < expiresAt) {
						return item;
					}
				}
				return null;
			}

			async function loadCode() {
				try {
					var separator = runtime.dataUrl.indexOf("?") === -1 ? "?" : "&";
					var response = await fetch(runtime.dataUrl + separator + "ts=" + Date.now(), {
						cache: "no-store",
						headers: { Accept: "application/json" },
					});
					if (!response.ok) throw new Error("bad_response");
					var payload = await response.json();
					var activeWindow = findActiveWindow(payload);
					if (!activeWindow) throw new Error("missing_window");

					currentCode = activeWindow.code || "";
					codeEl.textContent = currentCode || "----";
					expireEl.textContent = formatTime(activeWindow.expiresAt);
					statusEl.textContent = "";
				} catch (error) {
					currentCode = "";
					codeEl.textContent = "----";
					expireEl.textContent = "--";
					statusEl.textContent = runtime.labels.error;
				}
			}

			if (copyButton) {
				copyButton.addEventListener("click", async function () {
					if (!currentCode) return;
					try {
						await navigator.clipboard.writeText(currentCode);
						statusEl.textContent = runtime.labels.copied;
					} catch (error) {
						statusEl.textContent = runtime.labels.copyFailed;
					}
				});
			}

			loadCode();
		})();
	</script>
</MainGridLayout>
